{
  "name": "OpenFront speedrun",
  "description": "Speedruns for openfront.",
  "version": "1.1",
  "manifest_version": 3,
	"icons": {
		"16": "images/icon-16.png",
		"32": "images/icon-32.png",
		"64": "images/icon-64.png",
		"128": "images/icon-128.png"
	},
	"content_scripts": [
		{
			"js": ["dist/dist.js"],
			"matches": [
				"https://openfront.io/*",
				"https://playtest.openfront.dev/*"
			],
			"type": "module"
		}
	]
}
